{
  "name": "voice-flow-elevenlabs-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env MallocNanoZone= next dev",
    "build": "pnpm build:widget && cross-env MallocNanoZone= next build",
    "build:next": "cross-env MallocNanoZone= next build",
    "build:widget": "pnpm --filter @voiceflow/widget build",
    "start": "cross-env MallocNanoZone= next start",
    "lint": "cross-env MallocNanoZone= eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"widget/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"widget/**/*.{ts,tsx,css,json,md}\"",
    "typecheck": "tsc --noEmit",
    "verify:phase-2": "cross-env NODE_OPTIONS=\"--require ./scripts/server-only-shim.cjs\" tsx --env-file .env.local scripts/verify-phase-2.ts",
    "verify:prod": "node scripts/verify-prod.mjs"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.2",
    "@elevenlabs/client": "^1.8.1",
    "@elevenlabs/elevenlabs-js": "^2.49.1",
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
