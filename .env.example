# =============================================================================
# VoiceFlow — Environment Variables
# Copy this file to .env.local and fill in values per phase.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MongoDB Atlas)
# -----------------------------------------------------------------------------
MONGODB_URI=
MONGODB_DB_NAME=

# -----------------------------------------------------------------------------
# Auth (Auth.js v5 / next-auth@beta)
# Generate AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=
AUTH_TRUST_HOST=

# Google OAuth provider
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend magic link provider
AUTH_RESEND_KEY=
AUTH_RESEND_FROM=

# -----------------------------------------------------------------------------
# ElevenLabs (Conversational AI — browser + Twilio Media Streams)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI (OpenRouter -> Claude Sonnet 4.6 for post-call summaries)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# -----------------------------------------------------------------------------
# Email (Resend — transactional)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Stripe (usage-based metered billing — per-minute)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_METERED_MINUTES=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Security (encryption + HMAC for widget tokens)
# AES_ENCRYPTION_KEY: 32-byte hex (openssl rand -hex 32)
# WIDGET_JWT_SECRET: 32+ byte random string for HMAC signing
# -----------------------------------------------------------------------------
AES_ENCRYPTION_KEY=
WIDGET_JWT_SECRET=

# -----------------------------------------------------------------------------
# Twilio (NOT global — customers BYOK in dashboard; encrypted per-customer)
# These are only used for app-level operations (optional integration tests).
# -----------------------------------------------------------------------------
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Public (exposed to the browser — must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=VoiceFlow
