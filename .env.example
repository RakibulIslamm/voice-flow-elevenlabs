# =============================================================================
# VoiceFlow — Environment Variables
# Copy this file to .env.local and fill in values per phase.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MongoDB Atlas)
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# Auth (Auth.js v5 / next-auth@beta)
# Generate AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=

# Google OAuth provider
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend magic link provider
AUTH_RESEND_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# ElevenLabs (Conversational AI — browser + Twilio Media Streams)
# VoiceFlow is BYOK: users supply their own API key via the Integrations
# dashboard. The platform itself holds NO master ELEVENLABS_API_KEY.
# ELEVENLABS_WEBHOOK_SECRET is the platform-wide HMAC secret — every user
# configures this SAME value in their ElevenLabs webhook settings, which
# lets us verify all incoming post-call webhooks with one secret.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
ELEVENLABS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI (OpenRouter -> Claude Sonnet 4.6 for post-call summaries)
# Typical OPENROUTER_BASE_URL is https://openrouter.ai/api/v1
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=

# -----------------------------------------------------------------------------
# Stripe (usage-based metered billing — per-minute)
# Price IDs land in Phase 13.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Security
# ENCRYPTION_KEY: 32-byte hex (64 chars) — generate with: openssl rand -hex 32
# WIDGET_SIGNING_SECRET: 32+ char random string for HMAC widget JWTs
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
WIDGET_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Public (exposed to the browser — must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
