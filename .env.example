# =============================================================================
# VoiceFlow — Environment Variables
# Copy this file to .env.local and fill in values per phase.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MongoDB Atlas)
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# Auth (Auth.js v5 / next-auth@beta)
# Generate AUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=

# Google OAuth provider
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend magic link provider
AUTH_RESEND_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# ElevenLabs (Conversational AI — browser + Twilio Media Streams)
# VoiceFlow is BYOK end-to-end. No ElevenLabs env vars are required.
#   • API key — each user supplies via the Integrations page (encrypted).
#   • Webhook secret — ElevenLabs generates one per user when they create
#     the post-call webhook in their dashboard. The user pastes it into
#     the Integrations page (encrypted). Verified per-user inside the
#     webhook handler.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# AI (OpenRouter -> Claude Sonnet 4.6 for post-call summaries)
# Typical OPENROUTER_BASE_URL is https://openrouter.ai/api/v1
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=

# -----------------------------------------------------------------------------
# Stripe (recurring monthly + per-call metered overage)
# Tiers: Starter $19, Pro $49, Business $149. All paid tiers share a flat
# $0.005/call overage rate — the value of higher tiers is included quota +
# features (phone, more agents), not cheaper overage.
#
# In the Stripe Dashboard (test mode):
#   1. Create three Products with a recurring "flat" price each.
#   2. Create three matching usage-based recurring prices ($0.005/unit,
#      sum aggregation, no included quantity).
#   3. Create a Meter with event name `voicecalls`, aggregation = sum.
#   4. Paste all 6 price IDs below.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_OVERAGE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_OVERAGE_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_BUSINESS_OVERAGE_PRICE_ID=

# -----------------------------------------------------------------------------
# Polar.sh (alternative billing provider — for countries where Stripe is
# unavailable). When `POLAR_SDK=true`, the unified billing routes hit Polar
# instead of Stripe; otherwise Stripe stays the default. Only configure the
# provider you actually use.
#
# Setup steps (Polar Dashboard):
#   1. Create three Products — one per paid tier — each with a recurring
#      price ($19, $49, $149/mo) AND a metered price unit ($0.005/call).
#   2. Add a Webhook endpoint pointing at /api/polar/webhook and copy the
#      secret into POLAR_WEBHOOK_SECRET.
#   3. Paste each product ID below.
# POLAR_SERVER defaults to "sandbox" — set to "production" when going live.
# -----------------------------------------------------------------------------
POLAR_SDK=false
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
POLAR_BUSINESS_PRODUCT_ID=

# -----------------------------------------------------------------------------
# Security
# ENCRYPTION_KEY: 32-byte hex (64 chars) — generate with: openssl rand -hex 32
# WIDGET_SIGNING_SECRET: 32+ char random string for HMAC widget JWTs
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
WIDGET_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Public (exposed to the browser — must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
